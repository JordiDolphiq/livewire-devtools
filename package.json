{
  "name": "livewire-devtools",
  "version": "2.0.5",
  "description": "Chrome DevTools extension for debugging Livewire applications (v3 & v4).",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:fast": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "zip": "node scripts/zip.mjs",
    "release": "npm run build && npm run zip"
  },
  "dependencies": {
    "devalue": "^5.7.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.40",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.0.0"
  }
}
